// ============================================================
// AssetTable Component
// Renders a filterable, sortable asset table
// ============================================================

import { assets } from '../data/mockData.js';

export function renderAssetTable(filter = '', limit = null) {
  const statusPill = (s) => {
    const labels = { available: 'Available', out: 'Checked Out', maintenance: 'In Maintenance', retired: 'Retired' };
    return `<span class="status-pill ${s}"><span class="dot"></span>${labels[s]}</span>`;
  };

  let rows = assets.filter(a =>
    !filter ||
    a.name.toLowerCase().includes(filter) ||
    a.id.toLowerCase().includes(filter) ||
    a.category.toLowerCase().includes(filter)
  );

  if (limit) rows = rows.slice(0, limit);

  if (!rows.length) return `<tr><td colspan="7" style="text-align:center;padding:32px;color:var(--muted)">No assets found</td></tr>`;

  return rows.map(a => `
    <tr>
      <td>
        <div style="font-weight:500">${a.name}</div>
        <div style="font-size:11px;color:var(--muted);font-family:monospace">${a.id}</div>
      </td>
      <td style="color:var(--muted);font-size:12px">${a.category}</td>
      <td style="font-size:12px">${a.assignedTo || '—'}</td>
      <td style="color:var(--muted);font-size:12px">${a.location}</td>
      <td>${statusPill(a.status)}</td>
      <td style="font-size:12px">$${a.value.toLocaleString()}</td>
      <td>
        <button class="btn" style="padding:3px 10px;font-size:11px"
                onclick="showModal('edit','${a.id}')">Edit</button>
      </td>
    </tr>`).join('');
}
